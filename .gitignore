# ==========================================
# A-PAS .gitignore
# ==========================================

# 1. 가상환경 및 환경 설정
a-pas-env/
.env
.venv
__pycache__/
*.py[cod]

# 2. 대용량 데이터 폴더
ai_model/data/
raw_data/
dataset/

# 3. 대용량 파일 확장자
*.npy
*.csv
*.xlsx

# 4. 모델 가중치 및 학습 결과 (구조별 모든 폴더에 일괄 적용)
models/**/*.pth
models/**/*.onnx
models/**/*.png
models/**/eval/*.png
models/Residual/0427/*.png
models/Residual/0427/*.pth
models/Residual/0427/*.onnx
models/Kinematic/
*.pt                # YOLO 모델 파일 등

ai_model/trajectory/mcdropout/checkpoints/*.pt
ai_model/trajectory/mcdropout/*.onnx
ai_model/trajectory/mcdropout/figures/*.png
ai_model/trajectory/mcdropout/runs/

# 5. YOLO fine-tuning 데이터 및 결과
ai_model/yolo_train/carla_data*/
ai_model/yolo_train/carla_dataset*/
ai_model/yolo_train/runs/
ai_model/yolo_train/*.cache
embedded/carla_data*/
embedded/carla_data_v*/
embedded/*pt


# 6. 테스트 영상
*.mp4
*.avi

# 7. 이미지 (학습 데이터용)
*.jpg
*.jpeg
# 단, README 이미지는 유지 (필요 시 주석 해제)
# !docs/*.png
# !README_images/*.png

# 8. 임시/테스트 파일 및 IDE 설정
trash/
.DS_Store
Thumbs.db
.vscode/
.idea/
.ipynb_checkpoints/

# 9. 로그 및 결과
logs/
results/